# TokenRouter — used for both Whisper transcription and LLM scoring
TOKENROUTER_API_KEY=your_tokenrouter_key_here
TOKENROUTER_BASE_URL=https://api.tokenrouter.io/v1

# Infrastructure
REDIS_URL=redis://localhost:6379
DATABASE_URL=postgresql://clipper:clipper@localhost:5432/clipperai

# Optional: set to "true" to print raw librosa feature values for tuning
CALIBRATION=false

# ── Storage ───────────────────────────────────────────────────────────────────
# Choose where processed clips are stored.
# Options: "local" (default) | "s3" | "gcs"
STORAGE_PROVIDER=local

# Local storage — clips are served directly by the API at /clips/<job_id>/<file>
STORAGE_PATH=./storage/clips

# ── S3 / S3-compatible ────────────────────────────────────────────────────────
# Works with: AWS S3, Cloudflare R2, MinIO, Wasabi, DigitalOcean Spaces, etc.
# S3_BUCKET=my-clipper-bucket
# S3_REGION=us-east-1
# AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
# AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY

# For S3-compatible services, set the endpoint:
# S3_ENDPOINT_URL=https://<account>.r2.cloudflarestorage.com   # Cloudflare R2
# S3_ENDPOINT_URL=http://localhost:9000                         # MinIO

# Optional: public CDN/custom domain for clip URLs (overrides auto-generated URL)
# S3_PUBLIC_URL=https://clips.yourdomain.com

# Set to "" (empty) if your provider does not support ACLs (e.g. Cloudflare R2)
# S3_ACL=public-read

# ── Google Cloud Storage ──────────────────────────────────────────────────────
# GCS_BUCKET=my-clipper-bucket
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
