# TokenRouter — used for both Whisper transcription and LLM scoring
TOKENROUTER_API_KEY=your_tokenrouter_key_here
TOKENROUTER_BASE_URL=https://api.tokenrouter.io/v1

# Infrastructure
REDIS_URL=redis://localhost:6379
DATABASE_URL=postgresql://clipper:clipper@localhost:5432/clipperai
STORAGE_PATH=./storage/clips

# Optional: set to "true" to print raw librosa feature values for tuning
CALIBRATION=false
